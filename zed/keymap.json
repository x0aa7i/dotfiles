[
  // ── Workspace
  {
    "context": "Workspace",
    "bindings": {
      "alt-g": "git_panel::Toggle",
      "alt-e": "project_panel::Toggle",
      "alt-d": "debug_panel::Toggle",
      "alt-a": "agent::Toggle",
    },
  },

  // ── Project Panel
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "a": "project_panel::NewFile",
      "A": "project_panel::NewDirectory",
      "c": "project_panel::Copy",
      "d": "project_panel::Delete",
      "p": "project_panel::Paste",
      "r": "project_panel::Rename",
      "x": "project_panel::Cut",
      "O": "project_panel::RevealInFileManager",
      "H": "project_panel::CollapseAllEntries",
      "y": "workspace::CopyPath",
      "q": "workspace::ToggleLeftDock",
      "shift-y": "workspace::CopyRelativePath",
      "space e": "project_panel::Toggle",
    },
  },

  // ── Editor: Normal + Visual
  {
    "context": "Editor && (vim_mode == normal || vim_mode == visual) && !VimWaiting && !menu",
    "bindings": {
      "shift-l": ["workspace::SendKeystrokes", "g $"],
      "shift-h": ["workspace::SendKeystrokes", "g ^"],

      "ctrl-shift-c": "editor::Copy",
      "ctrl-shift-v": "editor::Paste",

      "s": "vim::PushSneak",
      "shift-s": "vim::PushSneakBackward",

      "ctrl-u": ["workspace::SendKeystrokes", "ctrl-u z z"],
      "ctrl-d": ["workspace::SendKeystrokes", "ctrl-d z z"],
      "ctrl-f": ["workspace::SendKeystrokes", "ctrl-f z z"],
      "ctrl-b": ["workspace::SendKeystrokes", "ctrl-b z z"],

      // Move lines up and down
      "alt-j": "editor::MoveLineDown",
      "alt-k": "editor::MoveLineUp",

      // Map j/k to gj/gk
      "j": ["vim::Down", { "display_lines": true }],
      "k": ["vim::Up", { "display_lines": true }],

      // Search
      "space s w": "buffer_search::Deploy", // Search word under cursor in current pane
      "space s W": "pane::DeploySearch", // Search word under cursor in all panes

      "g w": "vim::HelixJumpToWord", // Jump to word

      // Assistant
      "ctrl-i": "assistant::InlineAssist",
    },
  },

  // ── Editor: Normal
  {
    "context": "Editor && vim_mode == normal && !VimWaiting && !menu",
    "bindings": {
      "shift-y": ["workspace::SendKeystrokes", "y $"],
      "enter": ["workspace::SendKeystrokes", "c i w"],

      // Navigate panes
      "shift-q": "pane::CloseActiveItem",
      "tab": "pane::ActivateNextItem",
      "shift-tab": "pane::ActivatePreviousItem",
      "space space": "file_finder::Toggle",
      "space b o": "pane::CloseOtherItems",
      "space b b": "pane::AlternateFile", // Jump to the previous location
      "space f p": "projects::OpenRecent",

      // Open recent project
      "space s p": ["projects::OpenRecent", { "create_new_window": false }],

      // Split panel
      "ctrl-w": null,
      "space w h": "pane::SplitDown",
      "space w v": "pane::SplitRight",

      // Show panels
      "space e": "project_panel::Toggle",
      "space g p": "git_panel::Toggle",
      // Agent
      "space a c": "agent::ToggleFocus",
      "space a a": "agent::Toggle",

      // LSP
      "shift-k": "editor::Hover",
      "g d": "editor::GoToDefinition",
      "g D": "editor::GoToDefinitionSplit",
      "g i": "editor::GoToImplementation",
      "g I": "editor::GoToImplementationSplit",
      "g t": "editor::GoToTypeDefinition",
      "g T": "editor::GoToTypeDefinitionSplit",
      "g r": "editor::FindAllReferences",
      "g f": "editor::OpenExcerpts",

      // LSP / Code
      "space c a": "editor::ToggleCodeActions",
      "space c r": "editor::Rename",
      "space c f": "editor::Format",
      "space c i": "editor::OrganizeImports",
      "space c d": "editor::GoToDiagnostic",

      // Search
      "space s g": "pane::DeploySearch",
      "space s r": "buffer_search::DeployReplace",
      "space s s": "outline::Toggle",
      "space s S": "project_symbols::Toggle",

      // Git
      "space g b": "editor::ToggleGitBlameInline",
      "space g d": "git::Diff",
      "space g h d": "editor::ToggleSelectedDiffHunks",
      "space g h D": "editor::ExpandAllDiffHunks",
      "space g h s": "git::ToggleStaged",
      // "space g h S": "git::StageFile", // Not possible
      "space g h r": "git::Restore",
      "space g h R": "git::RestoreFile",
      "space g h a": "git::StageAndNext",
      "space g h u": "git::UnstageAndNext",
      "] h": "editor::GoToHunk",
      "[ h": "editor::GoToPreviousHunk",

      // UI Toggles
      "space u z": "workspace::ToggleCenteredLayout",
      "space u w": "editor::ToggleSoftWrap",
      "space u l": "editor::ToggleLineNumbers",
      "space u L": "editor::ToggleRelativeLineNumbers",
      "space u g": "editor::ToggleIndentGuides",
      "space u h": "editor::ToggleInlayHints",
      "space u d": "editor::ToggleInlineDiagnostics",
      "space u t": "theme_selector::Toggle",

      // Diagnostic
      "space x x": "diagnostics::Deploy",

      // Tasks
      "space g g": [
        "task::Spawn",
        { "task_name": "start lazygit", "reveal_target": "center" },
      ],
      "space g f": [
        "task::Spawn",
        { "task_name": "start lazygit file log", "reveal_target": "center" },
      ],
      "space -": [
        "task::Spawn",
        {
          "task_name": "yazi",
          "reveal_target": "center",
        },
      ],
    },
  },

  // ── Editor: Visual
  {
    "context": "Editor && vim_mode == visual && !VimWaiting && !menu",
    "bindings": {
      // visual, visual line & visual block modes
      ">": ["workspace::SendKeystrokes", "> g v"],
      "<": ["workspace::SendKeystrokes", "< g v"],
    },
  },

  // ── Editor: Insert
  {
    "context": "Editor && vim_mode == insert && !menu",
    "bindings": {
      "ctrl-shift-v": "editor::Paste",
      "ctrl-s": ["workspace::SendKeystrokes", "escape ctrl-s"],
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "j k": "vim::NormalBefore",
    },
  },

  // ── Editor: All Modes
  {
    "context": "Editor && !VimWaiting && !menu",
    "bindings": {
      "ctrl-c": "editor::Copy",
      "ctrl-x": "editor::Cut",
      "ctrl-v": "editor::Paste",
      "ctrl-a": "editor::SelectAll",
    },
  },
  {
    "context": "Editor && VimControl && !VimWaiting && !menu",
    "bindings": {
      "space t": "workspace::NewCenterTerminal",
      "space f b": "tab_switcher::ToggleAll",
    },
  },

  // ── Navigation
  {
    "context": "Terminal || Dock || Editor",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",

      "ctrl-\\": "terminal_panel::Toggle",
      "alt-q": "pane::CloseActiveItem",
    },
  },
  // ── Edit predictions
  {
    "context": "Editor && edit_prediction",
    "bindings": {
      "alt-tab": null,
      "alt-l": "editor::AcceptEditPrediction",
      "alt-]": "editor::AcceptNextWordEditPrediction",
      "alt-j": "editor::AcceptNextLineEditPrediction",
      // "alt-p": "editor::AcceptEditPrediction",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "alt-l": "pane::ActivateNextItem",
      "alt-h": "pane::ActivatePreviousItem",
    },
  },

  // ── Empty Pane
  {
    "context": "EmptyPane || SharedScreen",
    "bindings": {
      "space f": "file_finder::Toggle",
      "space space": "file_finder::Toggle",
      "space f p": "projects::OpenRecent",
    },
  },

  {
    "context": "SharedScreen || KeyContextView || MarkdownPreview",
    "bindings": {
      "shift-q": "pane::CloseActiveItem",
    },
  },

  // ── Git Panel
  {
    "context": "GitPanel && ChangesList",
    "bindings": {
      "space": "git::ToggleStaged",
    },
  },
  {
    "context": "GitPanel && !CommitEditor",
    "bindings": {
      "q": "workspace::ToggleLeftDock",
    },
  },

  // ── Menu Navigation
  // Refer to https://github.com/zed-industries/zed/pull/43618
  {
    "context": "vim_mode != insert",
    "bindings": {
      "ctrl-k": "menu::SelectPrevious",
      "ctrl-j": "menu::SelectNext",
    },
  },
  {
    "context": "vim_mode == insert || (showing_code_actions || showing_completions)",
    "bindings": {
      "ctrl-k": "editor::ContextMenuPrevious",
      "ctrl-j": "editor::ContextMenuNext",
    },
  },

  // Which Key
  {
    "context": "VimControl && !menu",
    "bindings": {
      "space": null, // Disable the default action vim::WrappingRight
    },
  },
]
