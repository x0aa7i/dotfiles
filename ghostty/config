# theme settings
theme = "/home/abdo/.config/ghostty/theme"
# font-family = "JetBrainsMono Nerd Font"
font-family = "Lilex"
# font-style = medium
# background-opacity = 0.8

# window settings
window-theme = ghostty
window-decoration = none
window-height = 50
window-width = 200
window-padding-balance = true
resize-overlay = never

gtk-single-instance = true
# gtk-tabs-location = bottom
gtk-wide-tabs = false

confirm-close-surface = false
cursor-invert-fg-bg = false

# allow read/write to the system clipboard (OSC 52)
# clipboard-read = allow
# clipboard-write = allow
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = false

# Other
copy-on-select = clipboard
shell-integration-features = cursor,sudo,no-title

initial-command = tmux new-session -A -s main
# initial-command = "fish -c 'tmux new-session -A -s main; exec fish'"

# keybindings
keybind = clear
# keybind = ctrl+h=goto_split:left
# keybind = ctrl+j=goto_split:bottom
# keybind = ctrl+k=goto_split:top
# keybind = ctrl+l=goto_split:right

keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+tab=previous_tab
keybind = ctrl+tab=next_tab
keybind = ctrl+shift+w=close_surface

# keybind = alt+l=next_tab
# keybind = alt+h=previous_tab

# keybind = ctrl+shift+enter=new_split:auto
# keybind = ctrl+-=new_split:down
# keybind = ctrl+|=new_split:up
# keybind = ctrl+==equalize_splits

keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard

keybind = alt+r=reload_config

